# ============================================================
# Smart Control Security — Demo Web
# Copia este archivo a .env y rellena los valores reales.
# NO COMMITEAR el archivo .env (ya está en .gitignore).
# ============================================================

# -------------------- Base de datos (Neon Postgres) --------------------
# Connection string completa desde Neon Console → Connection details
# Pooled (con pgbouncer) — para la app en runtime
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/scs_demo?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct (sin pooler) — solo para Prisma migrations
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/scs_demo?sslmode=require"

# -------------------- NextAuth --------------------
# En local: http://localhost:3000
# En Vercel: https://tu-proyecto.vercel.app (sin trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Genera con: npx auth secret  (o)  openssl rand -base64 32
NEXTAUTH_SECRET="cambiame-en-produccion-con-un-secreto-fuerte"

# -------------------- AWS S3 (fotos de marcas) --------------------
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."

# Nombre del bucket S3 (debe ser globalmente único en AWS)
# Sugerencia: scs-demo-fotos-2026
S3_BUCKET_NAME="scs-demo-fotos-2026"

# -------------------- Configuración del demo --------------------
# Distancia máxima permitida del puesto en metros antes de marcar como fraude
NEXT_PUBLIC_GEOFENCE_MAX_M="100"

# Precisión mínima aceptable del GPS en metros (rechaza si es peor)
NEXT_PUBLIC_GPS_PRECISION_MIN_M="50"

# Intervalo de polling del dashboard de supervisor (ms)
NEXT_PUBLIC_DASHBOARD_POLL_MS="5000"

# Modo demo (muestra banners explicativos)
NEXT_PUBLIC_DEMO_MODE="true"
