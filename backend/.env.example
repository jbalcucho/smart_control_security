# ============================================================
# Smart Control Security - Backend
# Plantilla de variables de entorno
#
# COPIA este archivo como `.env` y completa los valores reales.
# NUNCA commitees el archivo `.env` (está en .gitignore).
# ============================================================

# --- Entorno y servidor ---
ENVIRONMENT=local            # local | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
APP_NAME="Smart Control Security"
APP_VERSION=0.1.0
API_V1_PREFIX=/api

# Host y puerto en el que corre el backend localmente
HOST=0.0.0.0
PORT=8000

# CORS — orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Base de datos PostgreSQL + PostGIS ---
# Cuando uses docker-compose: postgres
# Cuando uses Postgres local en tu PC: localhost
DATABASE_URL=postgresql+asyncpg://scs_user:scs_password@localhost:5432/scs_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false          # true = imprime cada SQL (debug)

# --- Redis (cache, nonces, jobs) ---
REDIS_URL=redis://localhost:6379/0
REDIS_NONCE_TTL_SECONDS=600  # 10 minutos

# --- JWT / Autenticación ---
# IMPORTANTE: en producción genera estas claves con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CAMBIAME_EN_PRODUCCION_genera_con_secrets.token_urlsafe_64
JWT_ALGORITHM=HS256          # En producción cambiar a RS256 + par RSA
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- HMAC Request Signing ---
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300  # ±5 minutos

# --- AWS S3 (almacenamiento de fotos) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=smart-control-security-local
S3_USE_KMS=false             # En producción: true
S3_KMS_KEY_ID=
S3_PRESIGNED_URL_EXPIRES_SECONDS=900  # 15 min

# --- AWS Rekognition (Liveness + Face Matching) - Fase 3 ---
REKOGNITION_LIVENESS_MIN_CONFIDENCE=80
REKOGNITION_FACE_MATCH_MIN_SIMILARITY=90

# --- Google Play Integrity API - Fase 2/3 ---
GOOGLE_PLAY_PROJECT_NUMBER=
PLAY_INTEGRITY_ENABLED=false  # En desarrollo dejar false

# --- SendGrid (Fase 4) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@balcuapps.com
SENDGRID_FROM_NAME="Smart Control Security"

# --- Firebase Cloud Messaging (Fase 4) ---
# Ruta al archivo JSON de credenciales (no commitear el archivo)
FIREBASE_CREDENTIALS_PATH=secrets/firebase-service-account.json
FCM_ENABLED=false             # En desarrollo dejar false

# --- Sentry (Observabilidad) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Validaciones de negocio ---
FRAUD_VELOCITY_MAX_KMH=150   # umbral velocidad imposible
GEOFENCE_DEFAULT_RADIUS_METERS=50
MIN_GPS_PRECISION_METERS=50
